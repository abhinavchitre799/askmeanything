# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/widget_ai"
APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Encryption key for per-project API keys stored in the database (REQUIRED in
# production). Any string; it is hashed to a 32-byte AES key. If unset, an
# insecure dev key is used and a warning is logged.
#   generate one:  openssl rand -hex 32
# ---------------------------------------------------------------------------
APP_ENCRYPTION_KEY=""

# ---------------------------------------------------------------------------
# LLM provider (OPTIONAL global fallback for local dev only).
#
# Bring Your Own Key: each project sets its own provider + API key in the admin
# (Sources → "AI provider & API key"). Those per-project credentials take
# precedence. The variables below are only used as a fallback when a project has
# no key configured — leave them blank in a shared/public deployment so every
# project must supply its own key.
#
# Allowed values: "openai-compatible" | "google-gemini"
# ---------------------------------------------------------------------------
LLM_PROVIDER=""

# ---------------------------------------------------------------------------
# OpenAI-compatible provider (used when LLM_PROVIDER="openai-compatible")
# Works with OpenAI, Together, Groq, OpenRouter, Ollama, LM Studio, etc.
# ---------------------------------------------------------------------------
LLM_API_BASE_URL=""
LLM_API_KEY=""
LLM_CHAT_MODEL=""
LLM_EMBEDDING_MODEL=""

# ---------------------------------------------------------------------------
# Google Gemini provider (used when LLM_PROVIDER="google-gemini")
# Free-tier hosted option. Create a key at https://aistudio.google.com/apikey
# Example model values: your-gemini-chat-model / your-gemini-embedding-model
#   chat:       gemini-2.0-flash
#   embedding:  text-embedding-004
# ---------------------------------------------------------------------------
GOOGLE_GEMINI_API_KEY="your-google-gemini-api-key"
GOOGLE_GEMINI_CHAT_MODEL="your-gemini-chat-model"
GOOGLE_GEMINI_EMBEDDING_MODEL="your-gemini-embedding-model"

# ---------------------------------------------------------------------------
# Optional tuning
# ---------------------------------------------------------------------------
# Vector dimension stored in pgvector. Must match your embedding model output.
# Gemini text-embedding-004 -> 768. OpenAI text-embedding-3-small -> 1536.
EMBEDDING_DIMENSION="768"
# Max pages a single crawl job will fetch (MVP safety limit).
CRAWL_MAX_PAGES="50"

# Live-crawl fallback: when the knowledge base can't answer a question, crawl a
# few pages of the project's website on demand and retry. Set to "false" to off.
LIVE_CRAWL_FALLBACK="true"
# Max pages fetched during an on-demand live-crawl fallback (kept small).
LIVE_CRAWL_MAX_PAGES="5"
# Cosine-similarity threshold below which the KB is considered insufficient and
# the live-crawl fallback triggers. Tune per embedding model (~0..1).
RETRIEVAL_MIN_SIMILARITY="0.3"
